---
---

<section class="final" id="book">
	<div class="final-bg-container">
		<img src="https://res.cloudinary.com/dzaz02jrd/image/upload/v1777588740/ChatGPT_Image_Apr_30_2026_06_36_37_PM_qtxhh5.png" alt="Final Background" class="final-bg-img" />
		<div class="final-overlay"></div>
	</div>
	
	<div class="container final-inner">
		<span class="eyebrow">Your Move</span>
		<h2 class="final-headline">
			You've waited <span class="gold-text">long enough.</span>
		</h2>
		<p class="final-sub">
			Your first call is free. Your results are <em class="italic">permanent.</em>
		</p>
		
		<div class="final-cta">
			<a href="#" class="btn btn-large">Book Your Free Call <span class="arrow">↗</span></a>
		</div>
		
		<span class="final-fineprint">12 women | By Invitation | Manhattan & Remote</span>
	</div>
</section>

<style>
	.final {
		position: relative;
		padding: 120px 0;
		background: var(--black);
		text-align: center;
		overflow: hidden;
		min-height: 80vh;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.final-bg-container {
		position: absolute;
		inset: 0;
		z-index: 1;
	}

	.final-bg-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.final-overlay {
		position: absolute;
		inset: 0;
		background: rgba(0, 0, 0, 0.65);
	}

	.final-inner {
		position: relative;
		z-index: 10;
		display: flex;
		flex-direction: column;
		align-items: center;
		max-width: 900px;
	}

	.eyebrow {
		display: block;
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.3em;
		color: var(--gold);
		margin-bottom: 2.5rem;
	}

	.final-headline {
		font-size: clamp(3rem, 8vw, 6rem);
		line-height: 1.1;
		margin-bottom: 2rem;
		font-weight: 300;
	}

	.final-sub {
		font-size: 1.2rem;
		color: var(--ash);
		margin-bottom: 4rem;
		max-width: 600px;
	}

	.final-sub em {
		font-style: italic;
		font-weight: 300;
		color: var(--ivory);
	}

	.final-cta {
		margin-bottom: 3rem;
	}

	.btn-large {
		padding: 1.5rem 4rem;
		font-size: 1rem;
	}

	.final-fineprint {
		font-size: 0.75rem;
		color: rgba(255, 255, 255, 0.4);
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	@media (max-width: 600px) {
		.final {
			padding: 80px 4vw;
		}
		.final-sub {
			font-size: 1rem;
		}
	}
</style>

<script>
	import gsap from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';

	gsap.registerPlugin(ScrollTrigger);

	gsap.from('.final-inner > *', {
		scrollTrigger: {
			trigger: '.final',
			start: 'top 70%',
		},
		y: 40,
		opacity: 0,
		stagger: 0.15,
		duration: 1.2,
		ease: 'power3.out'
	});
</script>
