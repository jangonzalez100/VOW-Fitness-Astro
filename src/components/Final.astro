---
---

<section class="final" id="book">
	<div class="final-bg"></div>
	<div class="container final-inner">
		<span class="eyebrow">Your Move</span>
		<h2 class="final-headline">
			You've waited <span class="gold-text">long enough.</span>
		</h2>
		<p class="final-sub">
			Your first call is free. Your results are <em class="italic">permanent.</em>
		</p>
		
		<div class="final-cta">
			<a href="#" class="btn btn-large">Book Your Free Call <span class="arrow">↗</span></a>
		</div>
		
		<span class="final-fineprint">12 women · By Invitation · Manhattan & Remote</span>
	</div>
</section>

<style>
	.final {
		position: relative;
		padding: 15vw 0;
		background: var(--black);
		text-align: center;
		overflow: hidden;
	}

	.final-bg {
		position: absolute;
		inset: 0;
		background: radial-gradient(circle at 50% 100%, rgba(184, 144, 47, 0.15) 0%, transparent 70%);
		z-index: 1;
	}

	.final-inner {
		position: relative;
		z-index: 10;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.eyebrow {
		display: block;
		font-size: 0.8rem;
		text-transform: uppercase;
		letter-spacing: 0.3em;
		color: var(--gold);
		margin-bottom: 3rem;
	}

	.final-headline {
		font-size: clamp(3rem, 8vw, 6rem);
		line-height: 1;
		margin-bottom: 2rem;
	}

	.final-sub {
		font-size: 1.2rem;
		color: var(--ash);
		margin-bottom: 4rem;
	}

	.final-sub em {
		font-style: italic;
		font-weight: 300;
		color: var(--ivory);
	}

	.final-cta {
		margin-bottom: 2.5rem;
	}

	.btn-large {
		padding: 1.5rem 4rem;
		font-size: 1rem;
	}

	.final-fineprint {
		font-size: 0.75rem;
		color: #404040;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	@media (max-width: 600px) {
		.final-sub {
			font-size: 1rem;
		}
	}
</style>

<script>
	import gsap from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';

	gsap.registerPlugin(ScrollTrigger);

	gsap.from('.final-inner > *', {
		scrollTrigger: {
			trigger: '.final',
			start: 'top 70%',
		},
		y: 40,
		opacity: 0,
		stagger: 0.15,
		duration: 1.2,
		ease: 'power3.out'
	});
</script>
