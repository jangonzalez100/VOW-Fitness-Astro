---
const steps = [
	{
		n: "01",
		title: "Book a Free Call",
		italic: "Free Call",
		body: "Tell Anthony where you are, and where you want to go. Thirty minutes. No pitch, just a real conversation.",
		icon: "phone"
	},
	{
		n: "02",
		title: "Get Your Plan",
		italic: "Your Plan",
		body: "A program built around your life, your body, your hormones, your goals. Specific. Measurable. Yours.",
		icon: "document"
	},
	{
		n: "03",
		title: "See Real Results",
		italic: "Real Results",
		body: "Show up, follow the plan, transform. You'll feel it in week three. You'll see it in week six. It will hold for the next forty years.",
		icon: "chart"
	}
];
---

<section class="how" id="how">
	<div class="container">
		<div class="section-header">
			<span class="eyebrow">How It Works</span>
			<h2 class="section-title">Three steps to <em class="italic">the body you're after.</em></h2>
		</div>

		<div class="how-grid">
			{steps.map((step) => (
				<div class="how-step">
					<div class="step-num">{step.n}</div>
					<h3 class="step-title">
						{step.title.split(step.italic)[0]}
						<em class="italic">{step.italic}</em>
						{step.title.split(step.italic)[1]}
					</h3>
					<p class="step-body">{step.body}</p>
				</div>
			))}
		</div>

		<div class="how-image-wrapper">
			<img src="https://res.cloudinary.com/dzaz02jrd/image/upload/v1777588740/ChatGPT_Image_Apr_30_2026_06_33_48_PM_npjtlx.png" alt="Training Session" class="how-image" />
		</div>

		<div class="how-cta">
			<a href="#book" class="btn">Book Your Free Call <span class="arrow">↗</span></a>
		</div>
	</div>
</section>

<style>
	.how {
		padding: 120px 0;
		background: var(--black);
	}

	.section-header {
		text-align: center;
		margin-bottom: 8rem;
	}

	.eyebrow {
		display: block;
		font-size: 0.65rem;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		color: var(--gold);
		margin-bottom: 1.2rem;
	}

	.section-title {
		font-size: clamp(2rem, 4vw, 3rem);
		font-weight: 300;
	}

	.section-title em {
		font-style: italic;
		font-weight: 300;
	}

	.how-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 4rem;
		margin-bottom: 8rem;
	}

	.how-step {
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		text-align: left;
	}

	.step-num {
		font-family: 'Cormorant Garamond', serif;
		font-size: 64px;
		color: var(--gold);
		opacity: 0.15;
		line-height: 1;
		margin-bottom: 1rem;
	}

	.step-title {
		font-size: 1.6rem;
		margin-bottom: 1.2rem;
		font-weight: 300;
		position: relative;
		z-index: 2;
	}

	.step-title em {
		font-style: italic;
		font-weight: 300;
	}

	.step-body {
		font-size: 0.9rem;
		line-height: 1.6;
		color: var(--ash);
		max-width: 320px;
		position: relative;
		z-index: 2;
	}

	.how-image-wrapper {
		width: 100%;
		margin-bottom: 5rem;
		overflow: hidden;
	}

	.how-image {
		width: 100%;
		height: auto;
		display: block;
		object-fit: cover;
	}

	.how-cta {
		display: flex;
		justify-content: center;
		margin-top: 2rem;
	}

	@media (max-width: 1000px) {
		.how-grid {
			grid-template-columns: 1fr;
			gap: 4rem;
		}
		.how-step {
			align-items: center;
			text-align: center;
		}
		.section-header {
			margin-bottom: 4rem;
		}
	}
</style>

<script>
	import gsap from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';

	gsap.registerPlugin(ScrollTrigger);

	gsap.from('.how-step', {
		scrollTrigger: {
			trigger: '.how-grid',
			start: 'top 80%',
		},
		y: 30,
		opacity: 0,
		stagger: 0.2,
		duration: 1,
		ease: 'power3.out'
	});
</script>
