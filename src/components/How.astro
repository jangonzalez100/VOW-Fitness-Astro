---
const steps = [
	{
		n: "01",
		title: "Book a Free Call",
		italic: "Free Call",
		body: "Tell Anthony where you are, and where you want to go. Thirty minutes. No pitch, just a real conversation.",
		icon: "phone"
	},
	{
		n: "02",
		title: "Get Your Plan",
		italic: "Your Plan",
		body: "A program built around your life, your body, your hormones, your goals. Specific. Measurable. Yours.",
		icon: "document"
	},
	{
		n: "03",
		title: "See Real Results",
		italic: "Real Results",
		body: "Show up, follow the plan, transform. You'll feel it in week three. You'll see it in week six. It will hold for the next forty years.",
		icon: "chart"
	}
];
---

<section class="how" id="how">
	<div class="container">
		<div class="section-header">
			<span class="eyebrow">How It Works</span>
			<h2 class="section-title">Three steps to <em class="italic">the body you're after.</em></h2>
		</div>

		<div class="how-grid">
			{steps.map((step) => (
				<div class="how-step">
					<div class="step-num">{step.n}</div>
					<div class="step-icon-wrapper">
						{step.icon === 'phone' && (
							<svg viewBox="0 0 48 48" width="42" height="42" fill="none" stroke="currentColor" stroke-width="1">
								<rect x="6" y="9" width="36" height="32" />
								<path d="M6 17 H42" />
								<path d="M16 5 V13 M32 5 V13" stroke-linecap="square" />
								<circle cx="24" cy="28" r="4" />
							</svg>
						)}
						{step.icon === 'document' && (
							<svg viewBox="0 0 48 48" width="42" height="42" fill="none" stroke="currentColor" stroke-width="1">
								<path d="M10 6 H30 L40 16 V42 H10 Z" />
								<path d="M30 6 V16 H40" />
								<path d="M16 22 H32 M16 28 H32 M16 34 H26" stroke-linecap="square" />
							</svg>
						)}
						{step.icon === 'chart' && (
							<svg viewBox="0 0 48 48" width="42" height="42" fill="none" stroke="currentColor" stroke-width="1">
								<path d="M6 38 L18 26 L26 34 L42 16" stroke-linecap="square" />
								<path d="M32 16 H42 V26" stroke-linecap="square" />
							</svg>
						)}
					</div>
					<h3 class="step-title">
						{step.title.split(step.italic)[0]}
						<em class="italic">{step.italic}</em>
						{step.title.split(step.italic)[1]}
					</h3>
					<p class="step-body">{step.body}</p>
				</div>
			))}
		</div>

		<div class="how-cta">
			<a href="#book" class="btn">Book Your Free Call <span class="arrow">↗</span></a>
		</div>
	</div>
</section>

<style>
	.how {
		padding: var(--section-padding) 0;
		background: var(--black);
	}

	.section-header {
		text-align: center;
		margin-bottom: 5rem;
	}

	.eyebrow {
		display: block;
		font-size: 0.65rem;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		color: var(--gold);
		margin-bottom: 1.2rem;
	}

	.section-title {
		font-size: clamp(2rem, 4vw, 3rem);
		font-weight: 300;
	}

	.section-title em {
		font-style: italic;
		font-weight: 300;
	}

	.how-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 3rem;
		margin-bottom: 5rem;
	}

	.how-step {
		position: relative;
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
	}

	.step-num {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.75rem;
		color: var(--gold);
		margin-bottom: 1.5rem;
		opacity: 0.4;
	}

	.step-icon-wrapper {
		margin-bottom: 2rem;
		color: var(--gold-light);
		transition: transform 0.6s var(--transition-smooth);
	}

	.how-step:hover .step-icon-wrapper {
		transform: scale(1.1) rotate(5deg);
	}

	.step-title {
		font-size: 1.6rem;
		margin-bottom: 1.2rem;
		font-weight: 300;
	}

	.step-title em {
		font-style: italic;
		font-weight: 300;
	}

	.step-body {
		font-size: 0.9rem;
		line-height: 1.6;
		color: var(--ash);
		max-width: 280px;
	}

	.how-cta {
		display: flex;
		justify-content: center;
	}

	@media (max-width: 1000px) {
		.how-grid {
			grid-template-columns: 1fr;
			gap: 4rem;
		}
	}
</style>

<script>
	import gsap from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';

	gsap.registerPlugin(ScrollTrigger);

	gsap.from('.how-step', {
		scrollTrigger: {
			trigger: '.how-grid',
			start: 'top 80%',
		},
		y: 30,
		opacity: 0,
		stagger: 0.2,
		duration: 1,
		ease: 'power3.out'
	});
</script>
