---
import Monogram from './Monogram.astro';
---

<section class="hero" id="hero">
	<div class="hero-bg">
		<img src="https://res.cloudinary.com/dzaz02jrd/image/upload/v1777588740/ChatGPT_Image_Apr_30_2026_06_30_00_PM_okxnw6.png" alt="Hero Background" />
		<div class="hero-overlay"></div>
	</div>
	
	<div class="container hero-content">
		<div class="hero-monogram-wrapper">
			<Monogram size={140} className="hero-monogram" />
		</div>
		
		<h1 class="hero-headline">
			We help driven women <em class="italic">over 40</em> finally <span class="gold-text">transform their body</span>, for good.
		</h1>
		
		<div class="hero-details">
			<ul class="hero-desires">
				<li class="desire-item">Reclaim your energy</li>
				<li class="desire-dot"></li>
				<li class="desire-item">Build a body you're proud of</li>
				<li class="desire-dot"></li>
				<li class="desire-item">Feel like yourself again</li>
			</ul>
			
			<div class="hero-cta-group">
				<a href="#book" class="btn hero-btn">
					Book Your Free Call 
					<span class="arrow">↗</span>
				</a>
				<p class="hero-fineprint">A 30 minute conversation. No pitch.</p>
			</div>
		</div>
	</div>

	<div class="hero-scroll-indicator">
		<span class="scroll-text">Explore</span>
		<div class="scroll-line"></div>
	</div>
</section>

<style>
	.hero {
		position: relative;
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 120px 0 120px;
		overflow: hidden;
	}

	.hero-bg {
		position: absolute;
		inset: 0;
		z-index: -1;
	}

	.hero-bg img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.hero-overlay {
		position: absolute;
		inset: 0;
		background: rgba(0, 0, 0, 0.6);
	}

	.hero-content {
		position: relative;
		z-index: 10;
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.hero-monogram-wrapper {
		margin-bottom: 2rem;
	}

	.hero-headline {
		font-size: clamp(2.5rem, 6.5vw, 5rem);
		line-height: 1.1;
		max-width: 1100px;
		margin-bottom: 4rem;
		font-weight: 300;
	}

	.hero-headline em {
		font-family: 'Cormorant Garamond', serif;
		font-style: italic;
		font-weight: 300;
	}

	.gold-text {
		color: var(--gold-light);
	}

	.hero-details {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 3.5rem;
		width: 100%;
		max-width: 1100px;
	}

	.hero-desires {
		display: flex;
		align-items: center;
		gap: 1.5rem;
	}

	.desire-item {
		font-size: 0.85rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--ivory);
		white-space: nowrap;
	}

	.desire-dot {
		width: 4px;
		height: 4px;
		background: var(--gold);
		border-radius: 50%;
	}

	.hero-cta-group {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.8rem;
	}

	.hero-fineprint {
		font-size: 0.7rem;
		color: var(--ash);
		letter-spacing: 0.05em;
	}

	.hero-scroll-indicator {
		position: absolute;
		bottom: 2.5rem;
		left: 4vw;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.8rem;
	}

	.scroll-text {
		font-size: 0.65rem;
		text-transform: uppercase;
		letter-spacing: 0.3em;
		writing-mode: vertical-lr;
		color: var(--ash);
	}

	.scroll-line {
		width: 1px;
		height: 50px;
		background: linear-gradient(to bottom, var(--gold), transparent);
	}

	@media (max-width: 900px) {
		.hero {
			padding: 120px 4vw 80px;
		}
		.hero-desires {
			flex-direction: column;
			gap: 1rem;
		}
		.desire-dot {
			display: none;
		}
		.hero-headline {
			margin-bottom: 3rem;
		}
	}
</style>

<script>
	import gsap from 'gsap';

	const tl = gsap.timeline({ defaults: { ease: 'power4.out', duration: 1.5 } });

	const revealTargets = '.hero-monogram, .hero-headline, .desire-item, .hero-cta-group, .hero-scroll-indicator';

	// Ensure elements are initially hidden by GSAP
	gsap.set(revealTargets, { 
		opacity: 0,
		y: 20
	});

	tl.to('.hero-monogram', {
		scale: 1,
		opacity: 1,
		y: 0,
		rotate: 0,
		duration: 2,
	})
	.to('.hero-headline', {
		y: 0,
		opacity: 1,
	}, '-=1.2')
	.to('.desire-item', {
		x: 0,
		y: 0,
		opacity: 1,
		stagger: 0.15,
	}, '-=1')
	.to('.hero-cta-group', {
		y: 0,
		opacity: 1,
	}, '-=1')
	.to('.hero-scroll-indicator', {
		opacity: 1,
		y: 0
	}, '-=0.5');

	// Fallback: If timeline hasn't finished or elements are stuck
	setTimeout(() => {
		gsap.to(revealTargets, { opacity: 1, y: 0, duration: 1, stagger: 0.1, overwrite: 'auto' });
	}, 4000);

	// Parallax effect
	window.addEventListener('mousemove', (e) => {
		const { clientX, clientY } = e;
		const xPos = (clientX / window.innerWidth - 0.5) * 15;
		const yPos = (clientY / window.innerHeight - 0.5) * 15;

		gsap.to('.hero-monogram', {
			x: xPos,
			y: yPos,
			duration: 1.2,
			ease: 'power2.out'
		});
	});
</script>
