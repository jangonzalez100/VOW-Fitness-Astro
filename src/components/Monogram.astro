---
interface Props {
	size?: number;
	className?: string;
}

const { size = 64, className = "" } = Astro.props;
---

<img 
	src="https://res.cloudinary.com/dzaz02jrd/image/upload/v1777589842/ChatGPT_Image_Apr_30_2026_06_56_06_PM_bt2e3j.png" 
	alt="VOW Fitness Logo" 
	class={className} 
	width={size} 
	height={size} 
	style={{ objectFit: 'contain' }}
/>

<style>
	img {
		display: block;
	}
</style>
