---
const services = [
	{
		id: "01",
		name: "1-on-1 Personal Training",
		outcome: "A plan built around your life.",
		desc: "Private sessions in studio, two or three times a week. Strength, mobility, and recovery, written for the body you have today and the one you want next quarter.",
		meta: "Central Florida · In Person",
		price: "Investment discussed on your discovery call."
	},
	{
		id: "02",
		name: "Online Coaching",
		outcome: "Your training, on your runway.",
		desc: "Bespoke remote programming with weekly video reviews and daily check ins. The work travels with you instead of waiting on you.",
		meta: "Available Everywhere · Remote",
		price: "Investment discussed on your discovery call."
	},
	{
		id: "03",
		name: "Nutrition Coaching",
		outcome: "Your kitchen, finally on your side.",
		desc: "Built around how you actually eat. Your dinners, your travel, your hormones, your wine. Protocols, not diets. A literate plan you can follow without thinking.",
		meta: "Standalone or Paired · Remote",
		price: "Investment discussed on your discovery call."
	}
];

function highlightYour(text: string) {
	const parts = text.split(/(your)/i);
	return parts.map(part => part.toLowerCase() === 'your' ? `<em class="italic">${part}</em>` : part).join('');
}
---

<section class="services" id="services">
	<div class="container">
		<div class="section-header">
			<span class="eyebrow">Choose Your Path</span>
			<h2 class="section-title">Three ways to begin <em class="italic">the work.</em></h2>
		</div>

		<div class="services-grid">
			{services.map((service) => (
				<article class={`service-card reveal-card ${service.id === '03' ? 'has-bg' : ''}`}>
					{service.id === '03' && (
						<div class="card-bg-wrapper">
							<img src="https://res.cloudinary.com/dzaz02jrd/image/upload/v1777588743/ChatGPT_Image_Apr_30_2026_06_35_11_PM_az9nzq.png" alt="Nutrition Coaching" class="card-bg-img" />
							<div class="card-bg-overlay"></div>
						</div>
					)}
					<div class="s-top">
						<span class="s-id">{service.id}</span>
					</div>
					<div class="s-header">
						<h3 class="s-outcome" set:html={highlightYour(service.outcome)}></h3>
					</div>
					
					<div class="s-body">
						<h4 class="s-name">{service.name}</h4>
						<p class="s-desc">{service.desc}</p>
					</div>

					<div class="s-footer">
						<span class="s-meta">{service.meta}</span>
						<span class="s-price">{service.price}</span>
					</div>
				</article>
			))}
		</div>
	</div>
</section>

<style>
	.services {
		padding: 120px 0;
		background: var(--black);
		position: relative;
		z-index: 10;
	}

	.section-header {
		text-align: center;
		margin-bottom: 5rem;
	}

	.services-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
	}

	.service-card {
		background: #161616;
		padding: 48px;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		border-top: 2px solid var(--gold);
		transition: transform 0.5s var(--transition-smooth);
		position: relative;
		overflow: hidden;
		min-height: 520px;
	}

	.service-card.has-bg {
		border-top: none;
		background: transparent;
	}

	.card-bg-wrapper {
		position: absolute;
		inset: 0;
		z-index: 0;
	}

	.card-bg-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.card-bg-overlay {
		position: absolute;
		inset: 0;
		background: rgba(0, 0, 0, 0.7);
	}

	.service-card > *:not(.card-bg-wrapper) {
		position: relative;
		z-index: 2;
	}

	.service-card:hover {
		transform: translateY(-8px);
	}

	.s-id {
		display: block;
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.75rem;
		text-transform: uppercase;
		color: var(--gold);
		margin-bottom: 2rem;
	}

	.s-outcome {
		font-size: 1.8rem;
		line-height: 1.2;
		margin-bottom: 3rem;
		font-weight: 300;
	}

	:global(.s-outcome .italic) {
		font-style: italic;
		font-weight: 300;
	}

	.s-name {
		font-family: 'Montserrat', sans-serif;
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--ivory);
		margin-bottom: 1rem;
	}

	.s-desc {
		font-size: 0.9rem;
		line-height: 1.6;
		color: var(--ash);
		margin-bottom: 2.5rem;
	}

	.s-footer {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding-top: 1.5rem;
		border-top: 1px solid rgba(255, 255, 255, 0.05);
		font-size: 0.7rem;
		color: var(--ash);
	}

	.s-price {
		color: var(--ash);
		font-style: italic;
		font-size: 0.65rem;
	}

	@media (max-width: 1100px) {
		.services-grid {
			grid-template-columns: 1fr;
		}
		.service-card {
			padding: 40px 24px;
			min-height: auto;
		}
	}
</style>

<script>
	import gsap from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';

	gsap.registerPlugin(ScrollTrigger);

	// Set initial state via JS instead of CSS to avoid permanent invisibility if JS fails
	gsap.set('.reveal-card', { 
		opacity: 0,
		y: 40
	});

	ScrollTrigger.batch('.reveal-card', {
		onEnter: (batch) => {
			gsap.to(batch, {
				opacity: 1,
				y: 0,
				stagger: 0.15,
				duration: 1,
				ease: 'power2.out',
				overwrite: true
			});
		},
		start: 'top 85%',
		once: true
	});

	// Fallback: If ScrollTrigger hasn't fired after a few seconds, show them anyway
	setTimeout(() => {
		gsap.to('.reveal-card', { opacity: 1, y: 0, duration: 1, stagger: 0.1 });
	}, 3000);
</script>
